{
  "name": "vueey",
  "type": "module",
  "version": "0.0.4-beta.1",
  "packageManager": "pnpm@10.33.2",
  "description": "🤓 50 lines of code write Vue.js | 50行代码敲出Vue.js",
  "author": "tofu-xx <tofu-xx@foxmail.com>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/tofu-xx",
  "homepage": "https://github.com/tofu-xx/vueey#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofu-xx/vueey.git"
  },
  "bugs": "https://github.com/tofu-xx/vueey/issues",
  "keywords": [
    "vue",
    "minify",
    "minimal"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.es.js",
      "require": "./dist/main.umd.js"
    }
  },
  "main": "./dist/main.umd.js",
  "module": "./dist/main.es.js",
  "types": "./dist/main.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./dist/main.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "release": "bumpp -no-push && nr build && pnpm publish",
    "up": "taze minor -I --peer --maturity-period 14",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "old-build": "swc vue.js -o vue.min.js"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@antfu/ni": "^30.1.0",
    "@types/node": "^22.19.17",
    "bumpp": "^11.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-format": "^2.0.1",
    "taze": "^19.11.0",
    "tsc": "^2.0.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-dts": "^4.5.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
